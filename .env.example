# Use port 5433 when connecting to Docker Postgres from your host machine (5432 is often taken locally).
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/primetrade
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
LOG_LEVEL=INFO
